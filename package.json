{
  "name": "ru-worship-radio-app",
  "version": "1.0.0",
  "description": "RuWorshipRadioApp - Telegram Web App for listening to worship radio stations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/public && cp -r public/* dist/public/",
    "dev": "netlify dev",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "deploy": "yarn build && netlify deploy --prod",
    "netlify:dev": "netlify dev",
    "netlify:build": "netlify build"
  },
  "keywords": [
    "telegram",
    "radio",
    "web-app",
    "netlify",
    "serverless",
    "worship"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@netlify/functions": "^2.4.0",
    "dotenv": "^16.3.1",
    "next": "^16.1.1",
    "node-telegram-bot-api": "^0.64.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.5",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.11",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "netlify-cli": "^23.13.3",
    "typescript": "^5.0.0"
  }
}
